# =====================================================
# 1. CONFIGURACIONES GENERALES Y SEGURIDAD BÁSICA
# =====================================================
Options -Indexes        # Evita que se listen los directorios si no hay index.php
Options -MultiViews     # Evita conflictos de negociación de contenido
# ServerSignature Off     # Oculta la versión del servidor en páginas de error (Seguridad)

# Bloquea el acceso público a archivos ocultos (ej: .env, .git, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# =====================================================
# 2. MANEJO DE CABECERAS DE AUTORIZACIÓN
# =====================================================
CGIPassAuth On          # La forma oficial y moderna para FastCGI/FPM

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Backup para rescatar el token en servidores obstinados/antiguos
    SetEnvIfNoCase ^Authorization$ "(.+)" HTTP_AUTHORIZATION=$1
    RewriteCond %{HTTP:Authorization} ^(.*)
    RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

    # =====================================================
    # 3. ENRUTAMIENTO PRINCIPAL DE LA API (FRONT CONTROLLER)
    # =====================================================
    RewriteCond %{REQUEST_FILENAME} !-f     # Si lo que se pide NO es un archivo real...
    RewriteCond %{REQUEST_FILENAME} !-d     # Y NO es un directorio real...
    RewriteRule ^(.*)$ index.php [QSA,L]    # Redirige todo silenciosamente a index.php para que el Router de PHP lo maneje
</IfModule>