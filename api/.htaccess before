Options All -Indexes
Options -MultiViews

RewriteEngine On
# RewriteCond %(REQUEST_FILENAME) !-f
RewriteCond %{REQUEST_FILENAME} !-f
# RewriteRule ^ index.php [QSA,t]
RewriteRule ^ index.php [QSA,L]

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Pasa el header Authorization a PHP
    RewriteCond %{HTTP:Authorization} ^(.*)
    RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]
</IfModule>

# Opción alternativa para algunas versiones de Apache
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1