# Plantilla de variables de entorno para redim_backend.
# Copia este archivo como ".env" y coloca TUS propios valores.
# Genera secretos fuertes y NO reutilices los de ejemplo.
#   php -r "echo bin2hex(random_bytes(32));"   (o)   openssl rand -hex 32

# --- Seguridad ---
# Clave para firmar/verificar los JWT (hex de 64 caracteres)
JWT_SECRET=cambia_esto_por_un_hex_aleatorio_de_64
# Minutos de vida del token de acceso
JWT_EXP_MINUTES=5
# Clave maestra para operaciones de recuperacion/administracion
MASTER_KEY=cambia_esto_por_otra_cadena_aleatoria

# --- Base de datos ---
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=nombre_de_tu_bd

# --- Otros ---
API_BASE_PATH=
